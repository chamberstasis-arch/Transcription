# Backend / FastAPI
LOCAL_MEDIA_DIR=/code/audio_test
KEEP_TEMP_FILES=false

# Seguridad / acceso remoto (túnel SSH o Tailscale; no exponer públicamente)
# API_KEYS: claves válidas separadas por coma. Vacío = sin auth (modo local abierto).
#           Con valor, el front pide login una vez y guarda una cookie de sesión.
#           Los clientes programáticos (curl/scripts) pueden usar el header X-API-Key.
API_KEYS=
# Secreto para firmar la cookie de sesión. Vacío = derivado de API_KEYS
# (rotar las claves invalida las sesiones). Define uno fijo para sesiones estables.
SESSION_SECRET=
# Vigencia de la sesión en horas.
SESSION_TTL_HOURS=168
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# Límite de tamaño de subida en MB.
MAX_UPLOAD_MB=200

# CORS: solo necesario si sirves el front desde OTRO origen (no same-origin).
# Con el front servido por el backend, no hace falta.
FRONTEND_ORIGIN=http://localhost:5173
CORS_ALLOW_ORIGINS=

# Interfaz/puerto donde se publica el contenedor en el host.
#   127.0.0.1 = solo accesible vía túnel SSH local. 0.0.0.0 = todas las interfaces.
API_BIND_HOST=0.0.0.0
API_PORT=8000

# Transcription
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=
TRANSCRIPTION_CHUNK_SECONDS=600
